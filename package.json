    "recharts": "^2.15.2",
    "resend": "^4.0.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.1.12",
    "components": "0.1.0",
    "framer-motion": "12.23.24",
    "lib": "5.1.0",
    "features": "0.1.0",
    "fs": "0.0.1-security",
    "path": "0.12.7",
    "next": "16.0.1",
    "express": "5.1.0",
    "cors": "2.8.5",
    "dotenv": "17.2.3"
  },
  "devDependencies": {
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "10.4.2",
    "globals": "^15.15.0",
    "postcss": "^8.5.6",
    "prettier": "^3.5.3",

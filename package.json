{
  "name": "agi-gateway",
  "private": true,
  "homepage": "https://agigateway.co.nz",
  "version": "0.0.1",
  "type": "module",
  "Critical": {
    "dependencies": [
      "react",
      "react-dom",
      "prop-types",
      "react-router-dom",
      "@tailwindcss/typography",
      "recharts"
    ],
    "devDependencies": [
      "@vitejs/plugin-react",
      "vite",
      "typescript",
      "@types/react",
      "@types/react-dom",
      "@typescript-eslint/eslint-plugin",
      "@typescript-eslint/parser",
      "typescript-eslint",
      "tailwindcss",
      "autoprefixer",
      "postcss",
      "eslint",
      "prettier"
    ],
    "scripts": [
      "start",
      "build",
      "lint",
      "lint:fix",
      "format",
      "preview",
      "serve",
      "type-check",
      "predeploy",
      "deploy"
    ],
    "warning": "CRITICAL: DO NOT REMOVE OR MODIFY ABOVE DEPENDENCIES - Required for TypeScript React app functionality"
  },
  "scripts": {
    "dev": "vite",
    "build": "node src/scripts/generate-sitemap.mjs && tsc --noCheck && vite build",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md,json}\"",
    "preview": "vite preview",
    "serve": "vite preview",
    "type-check": "tsc --noEmit",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.10",
